---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import Image from "@core-elements/image/Image.astro";

const {
  heading = "Our leadership team",
  members = [],

  colorScheme = "inherit",
  backgroundColor,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  class:list={["team-grid", className]}
  maxContentWidth="3xl"
  paddingHorizontal="xl"
  paddingVertical="4xl"
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <Heading level="h2" size="2xl" alignX="center" text={heading} data-prop="heading" />

  <div class="team-grid__grid" data-editable="array" data-prop="members">
    {members.map((member) => (
      <div class="team-grid__member" data-editable="array-item" data-id="page-sections/people/team-grid/member">
        <Image
          source={member.image?.source}
          alt={member.image?.alt}
          aspectRatio="square"
          rounded={true}
        />
        <Heading level="h3" size="xs" alignX="center" data-prop="name">{member.name}</Heading>
        <SimpleText text={member.title} size="sm" alignX="center" data-prop="title" />
      </div>
    ))}
  </div>
</CustomSection>

<style is:global>
  @layer page-sections {
    .team-grid__grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-xl);
      width: 100%;
      margin-top: var(--spacing-2xl);
    }

    @media (max-width: 768px) {
      .team-grid__grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .team-grid__member {
      text-align: center;
    }

    .team-grid__member .image {
      margin-top: 0;
      border-radius: var(--radius-lg);
      overflow: hidden;
    }

    .team-grid__member .heading {
      margin-top: var(--spacing-sm);
    }

    .team-grid__member .simple-text {
      color: var(--color-text-muted);
    }
  }
</style>
